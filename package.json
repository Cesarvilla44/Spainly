{
  "name": "spainly",
  "version": "1.0.0",
  "description": "Plataforma de turismo de España con TypeScript y React",
  "main": "src/app.ts",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "tsx src/app.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "serve .",
    "type-check": "tsc --noEmit"
